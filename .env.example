# Root backend environment file.
# Copy this file to `.env` and replace the placeholder values.
# This file is used by the FastAPI backend and docker-compose.
# Do not put frontend Vite variables here; use `frontend/.env.local` for those.

# -----------------------------------------------------------------------------
# Backend runtime
# -----------------------------------------------------------------------------
PORT=8080
LOG_LEVEL=INFO
FFMPEG_BINARY=ffmpeg
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
MEETING_HISTORY_DB_PATH=data/meeting_history.sqlite3
RAW_AUDIO_RETENTION_ENABLED=1
RAW_AUDIO_DIR=data/raw_audio
# Optional default glossary. Use semicolons/new lines, or entries like term=>replacement.
CUSTOM_GLOSSARY_TERMS=
# Set to 1 for deterministic local ASR, translation, summary, and analysis.
# Demo mode is for local development, documentation smoke tests, and CI only.
DEMO_MODE=0

# -----------------------------------------------------------------------------
# Provider selection
# -----------------------------------------------------------------------------
# Supported values: volcengine, dashscope, demo.
# Volcengine Doubao returns native speaker clustering.
# DashScope paraformer-realtime-v1 can use hybrid diarization when enabled below.
# demo requires DEMO_MODE=1 and does not call external AI providers.
DEFAULT_ASR_PROVIDER=volcengine

# -----------------------------------------------------------------------------
# DashScope: chat, translation, and Paraformer realtime ASR
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_TRANSLATION_MODEL=qwen-mt-flash
DASHSCOPE_ASR_MODEL=paraformer-realtime-v1
DASHSCOPE_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
DASHSCOPE_WORKSPACE_ID=

# -----------------------------------------------------------------------------
# Volcengine Doubao ASR
# -----------------------------------------------------------------------------
VOLCENGINE_ASR_APP_KEY=your-volcengine-app-key
VOLCENGINE_ASR_ACCESS_KEY=your-volcengine-access-key
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
VOLCENGINE_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
VOLCENGINE_ASR_NOSTREAM_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
VOLCENGINE_ASR_SSD_VERSION=200

# -----------------------------------------------------------------------------
# Speaker diarization
# -----------------------------------------------------------------------------
# Supported values:
# - disabled: no backend diarization. Volcengine native speaker output still works.
# - offline: DashScope transcripts are speaker-confirmed only after meeting end.
# - hybrid: DashScope paraformer-realtime-v1 uses live diart speaker updates during
#   the meeting, then confirms final speakers with pyannote after meeting end.
DIARIZATION_MODE=disabled

# Hugging Face token used by both pyannote offline diarization and the optional
# diart realtime worker. The account must accept the required model terms on
# Hugging Face.
HUGGINGFACE_TOKEN=

# Store Hugging Face downloads inside this project instead of the default user
# cache on C:. Relative paths are resolved from the project root.
HF_HOME=models/huggingface
# pyannote.audio 3.x uses PYANNOTE_CACHE separately from HF_HOME. Point it to
# the same hub cache so diart can reuse the pre-downloaded pyannote models.
PYANNOTE_CACHE=models/huggingface/hub
# Windows often blocks non-admin symlink creation. Disable Hugging Face cache
# symlinks so model downloads copy files instead of failing with WinError 1314.
HF_HUB_DISABLE_SYMLINKS=1
# Enable after the required Hugging Face models are already downloaded. Disable
# or remove this when changing models or downloading them for the first time.
HF_HUB_OFFLINE=0
# pyannote.audio 3.x checkpoints are trusted project dependencies but are not
# compatible with PyTorch 2.6+ weights_only=True default loading behavior.
TORCH_FORCE_NO_WEIGHTS_ONLY_LOAD=1

# Final offline pyannote model, executed in the main backend venv:
#   backend\.venv
# This is the end-of-meeting confirmation model and is not passed to diart.
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1

# Realtime diart settings for DIARIZATION_MODE=hybrid.
# These only apply to DashScope + DASHSCOPE_ASR_MODEL=paraformer-realtime-v1.
REALTIME_DIARIZATION_DURATION_SECONDS=5
REALTIME_DIARIZATION_STEP_SECONDS=0.5
REALTIME_DIARIZATION_LATENCY_SECONDS=1

# Explicit realtime diart models. These are diart component models, not the
# final pyannote diarization pipeline above.
DIART_SEGMENTATION_MODEL=pyannote/segmentation
DIART_EMBEDDING_MODEL=pyannote/embedding

# Optional but recommended for DIARIZATION_MODE=hybrid:
# point this to a separate Python environment that has diart==0.9.2 installed.
#
# Why separate?
# - Main backend venv uses pyannote.audio 4.x, which requires numpy>=2.
# - diart 0.9.2 requires numpy<2.
# Keeping diart in a separate env avoids breaking the final pyannote confirmation.
#
# Example Windows path:
# DIART_PYTHON_PATH=D:\Project\smart-meeting-assistant\backend\.venv-diart\Scripts\python.exe
DIART_PYTHON_PATH=
