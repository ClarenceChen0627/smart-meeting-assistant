# Root backend environment file.
# Copy this file to `.env` and replace the placeholder values.
# This file is used by:
# - FastAPI backend
# - docker-compose
# Do not put frontend Vite variables here.

DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_ASR_MODEL=paraformer-realtime-v1
DASHSCOPE_TRANSLATION_MODEL=qwen-mt-flash

PORT=8080
LOG_LEVEL=INFO
SUMMARY_INTERVAL=10
FFMPEG_BINARY=ffmpeg
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
